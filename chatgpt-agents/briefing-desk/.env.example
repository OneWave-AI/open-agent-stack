# Briefing Desk — connector credentials
# Copy to .env and fill in. Never commit real secrets.

# --- OpenAI (Assistants API portability path) ---
OPENAI_API_KEY=

# --- Web connector ---
# Search/fetch provider key for topic research.
WEB_SEARCH_API_KEY=

# --- Gmail connector (read-only) ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# --- Slack connector (read tracked channels + post delivery) ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
# Default channel the scheduled briefing is posted to.
SLACK_DEFAULT_CHANNEL_ID=

# --- Email delivery ---
# Address the agent sends briefings from / receives on-demand requests at.
BRIEFING_FROM_ADDRESS=
BRIEFING_DELIVER_TO=
