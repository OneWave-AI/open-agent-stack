# Pipeline Pulse — connector credentials
# Copy to .env and fill in real values. Never commit real secrets.

# --- Salesforce (read-only) ---
SALESFORCE_INSTANCE_URL=https://your-instance.my.salesforce.com
SALESFORCE_CLIENT_ID=your-connected-app-client-id
SALESFORCE_CLIENT_SECRET=your-connected-app-client-secret
SALESFORCE_USERNAME=your-integration-user@example.com
SALESFORCE_PASSWORD=your-integration-user-password
SALESFORCE_SECURITY_TOKEN=your-security-token
SALESFORCE_API_VERSION=v60.0

# --- Slack (digest delivery + on-demand invocation) ---
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_CHANNEL_ID=C0000000000

# --- Agent config ---
# Stalled-deal threshold in calendar days
STALLED_THRESHOLD_DAYS=14
# Cron expression for the scheduled run (weekday 8:00 AM by default)
PULSE_SCHEDULE_CRON=0 8 * * 1-5
# Workspace time zone for the schedule
PULSE_TIMEZONE=America/New_York
