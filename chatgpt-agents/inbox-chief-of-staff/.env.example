# Inbox Chief of Staff — connector and API key inventory
#
# Workspace Agents authorize Gmail and Google Calendar via OAuth in the
# connector panel, so no keys are needed there. These placeholders apply only
# when self-hosting the equivalent via the OpenAI Assistants API (see README
# Portability note). Copy to .env and fill in. Never commit real secrets.

# OpenAI Assistants API
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ASSISTANT_ID=asst_your-assistant-id

# Google OAuth (Gmail + Calendar tool wrappers)
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REFRESH_TOKEN=your-google-oauth-refresh-token

# Gmail / Calendar API scopes (space-separated, adjust as needed)
GOOGLE_API_SCOPES=https://www.googleapis.com/auth/gmail.modify https://www.googleapis.com/auth/calendar

# Email channel (inbound address the agent watches; outbound digest target)
AGENT_INBOUND_ADDRESS=inbox-chief-of-staff@your-workspace.example
DIGEST_DELIVERY_ADDRESS=you@your-workspace.example

# Scheduler (cron worker that triggers runs when self-hosting)
RUN_SCHEDULE_CRON=0 * * * *
