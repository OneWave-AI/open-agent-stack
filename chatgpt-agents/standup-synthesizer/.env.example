# Standup Synthesizer — environment template
# Copy to .env and fill in real values. Never commit real secrets.

# --- Slack connector ---
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
# Comma-separated channels the agent may read
SLACK_CHANNELS=#eng-standup,#product,#design
# Channel scheduled runs post to
SLACK_DEFAULT_CHANNEL=#eng-standup

# --- Notion connector ---
NOTION_API_KEY=secret_your-notion-integration-token
# Comma-separated page or database IDs in scope
NOTION_SCOPE=your-team-tasks-db-id,your-sprint-page-id

# --- Atlassian connector (Jira + Confluence) ---
ATLASSIAN_BASE_URL=https://your-domain.atlassian.net
ATLASSIAN_EMAIL=service-account@your-domain.com
ATLASSIAN_API_TOKEN=your-atlassian-api-token
# Comma-separated Jira project keys and Confluence space keys in scope
ATLASSIAN_SCOPE=ENG,PROD

# --- Agent runtime ---
AGENT_TIMEZONE=America/New_York
# Cron for the daily standup (weekdays at 09:00)
STANDUP_CRON=0 9 * * 1-5
