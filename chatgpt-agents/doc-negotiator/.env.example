# doc-negotiator connector credentials
# Copy to .env and fill with real values. Never commit real secrets.

# Google Drive (read-only)
GOOGLE_DRIVE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_DRIVE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_DRIVE_REFRESH_TOKEN=your-google-oauth-refresh-token
GOOGLE_DRIVE_CONTRACTS_FOLDER_ID=your-contracts-folder-id

# Microsoft SharePoint (read-only)
SHAREPOINT_TENANT_ID=your-azure-tenant-id
SHAREPOINT_CLIENT_ID=your-azure-app-client-id
SHAREPOINT_CLIENT_SECRET=your-azure-app-client-secret
SHAREPOINT_SITE_ID=your-sharepoint-site-id
SHAREPOINT_LIBRARY_ID=your-contracts-document-library-id

# Notion (read-only integration)
NOTION_API_KEY=your-notion-internal-integration-token
NOTION_CONTRACTS_DATABASE_ID=your-notion-contracts-database-id
NOTION_POLICY_PAGE_ID=your-notion-policy-root-page-id

# Email channel (inbound trigger + reply)
AGENT_INBOUND_EMAIL=doc-negotiator@your-workspace-domain
EMAIL_REPLY_FROM=doc-negotiator@your-workspace-domain
