{
  "$schema": "https://design-tokens.org/schema.json",
  "$description": "Mono-brutalist: stark monochrome, maximum contrast, hard rectangular containers, thick borders, oversized condensed type, instant no-easing state changes. Light base.",
  "color": {
    "$type": "color",
    "bg": {
      "base": { "$value": "#FFFFFF", "$description": "Pure white page background." },
      "raised": { "$value": "#F2F2F2", "$description": "Raised panel fill, faint gray separation." }
    },
    "surface": { "$value": "#FFFFFF", "$description": "Card and container fill." },
    "text": {
      "primary": { "$value": "#000000", "$description": "Pure black body and heading text. 21:1 on white." },
      "muted": { "$value": "#4A4A4A", "$description": "Muted gray text. 8.9:1 on white, AA+." }
    },
    "accent": { "$value": "#000000", "$description": "Accent is pure black inversion. Monochrome by intent." },
    "border": { "$value": "#000000", "$description": "Thick solid black container borders." },
    "divider": { "$value": "#000000", "$description": "Black rule dividers." }
  },
  "type": {
    "font": {
      "display": { "$type": "fontFamily", "$value": ["Archivo Narrow", "Arial Narrow", "Helvetica Neue", "Arial", "sans-serif"], "$description": "Oversized condensed display face." },
      "body": { "$type": "fontFamily", "$value": ["Helvetica Neue", "Helvetica", "Arial", "sans-serif"] },
      "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "SFMono-Regular", "Menlo", "Consolas", "monospace"] }
    },
    "weight": {
      "regular": { "$type": "fontWeight", "$value": 400 },
      "medium": { "$type": "fontWeight", "$value": 500 },
      "bold": { "$type": "fontWeight", "$value": 700 },
      "black": { "$type": "fontWeight", "$value": 900 }
    },
    "scale": {
      "xs": { "$type": "dimension", "$value": "0.75rem" },
      "sm": { "$type": "dimension", "$value": "0.875rem" },
      "base": { "$type": "dimension", "$value": "1rem" },
      "lg": { "$type": "dimension", "$value": "1.25rem" },
      "xl": { "$type": "dimension", "$value": "1.75rem" },
      "2xl": { "$type": "dimension", "$value": "2.5rem" },
      "3xl": { "$type": "dimension", "$value": "3.75rem" },
      "4xl": { "$type": "dimension", "$value": "5.5rem" }
    }
  },
  "space": {
    "$type": "dimension",
    "0": { "$value": "0" },
    "1": { "$value": "0.25rem" },
    "2": { "$value": "0.5rem" },
    "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" },
    "5": { "$value": "1.5rem" },
    "6": { "$value": "2rem" },
    "7": { "$value": "3rem" },
    "8": { "$value": "4rem" },
    "9": { "$value": "6rem" }
  },
  "radius": {
    "$type": "dimension",
    "container": { "$value": "0", "$description": "Zero radius. Hard rectangular containers." },
    "control": { "$value": "0", "$description": "Zero radius on all controls." }
  },
  "border": {
    "$type": "dimension",
    "width": {
      "rule": { "$value": "1px", "$description": "Thin rule divider." },
      "solid": { "$value": "3px", "$description": "Standard thick container border." },
      "heavy": { "$value": "5px", "$description": "Heavy emphasis border." }
    }
  },
  "elevation": {
    "$type": "shadow",
    "none": { "$value": { "offsetX": "0", "offsetY": "0", "blur": "0", "spread": "0", "color": "transparent" }, "$description": "No soft shadows. Brutalist surfaces are flat." },
    "hard": { "$value": { "offsetX": "6px", "offsetY": "6px", "blur": "0", "spread": "0", "color": "#000000" }, "$description": "Hard offset block shadow, zero blur." }
  },
  "motion": {
    "duration": {
      "instant": { "$type": "duration", "$value": "0ms", "$description": "Instant state changes. No transition." },
      "fast": { "$type": "duration", "$value": "60ms" }
    },
    "easing": {
      "none": { "$type": "cubicBezier", "$value": [0, 0, 1, 1], "$description": "Linear. No easing curve." },
      "step": { "$type": "cubicBezier", "$value": [1, 0, 1, 0], "$description": "Hard step, snap to end." }
    },
    "signature": { "$type": "string", "$value": "Instant binary state flip: invert fill and text on interaction with zero transition.", "$description": "Signature motion for the style." }
  }
}
