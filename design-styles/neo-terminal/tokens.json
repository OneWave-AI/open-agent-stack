{
  "$schema": "https://design-tokens.org/schema.json",
  "$description": "neo-terminal: AI-console / cyber design style. Near-black phosphor-green and amber mono aesthetic with dot-grid and scanline treatments, bordered panels with corner ticks, and typewriter motion. Dark base, no purple, WCAG AA+ contrast.",
  "color": {
    "$type": "color",
    "bg": {
      "base": {
        "$value": "#05080a",
        "$description": "Page background. Near-black with a faint cool cast."
      },
      "raised": {
        "$value": "#0a1014",
        "$description": "Raised regions and grouped sections above the base."
      }
    },
    "surface": {
      "$value": "#0e161b",
      "$description": "Panel and card surface sitting on bg.raised."
    },
    "text": {
      "primary": {
        "$value": "#d6f5e3",
        "$description": "Primary text. Soft phosphor white-green on dark. Contrast 14.8:1 on bg.base."
      },
      "muted": {
        "$value": "#7fa394",
        "$description": "Secondary / muted text. Contrast 6.1:1 on bg.base."
      }
    },
    "accent": {
      "$value": "#39ff8b",
      "$description": "Primary phosphor-green accent. Contrast 13.6:1 on bg.base.",
      "$extensions": {
        "neo-terminal.alt": {
          "$value": "#ffb627",
          "$description": "Amber secondary accent for warnings, highlights, cursor. Contrast 11.1:1 on bg.base."
        },
        "neo-terminal.danger": {
          "$value": "#ff5c5c",
          "$description": "Error / destructive signal. Contrast 6.4:1 on bg.base."
        }
      }
    },
    "border": {
      "$value": "#1d3a2f",
      "$description": "Panel borders and corner ticks. Dim phosphor line."
    },
    "divider": {
      "$value": "#16302a",
      "$description": "Dotted / dashed divider color between rows and sections."
    }
  },
  "type": {
    "font": {
      "display": {
        "$type": "fontFamily",
        "$value": ["JetBrains Mono", "IBM Plex Mono", "ui-monospace", "monospace"],
        "$description": "Display headings. Monospace, used at heavier weight and tracking."
      },
      "body": {
        "$type": "fontFamily",
        "$value": ["JetBrains Mono", "IBM Plex Mono", "ui-monospace", "monospace"],
        "$description": "Body text. Monospace throughout the system."
      },
      "mono": {
        "$type": "fontFamily",
        "$value": ["JetBrains Mono", "IBM Plex Mono", "ui-monospace", "SFMono-Regular", "monospace"],
        "$description": "Code and data. Same monospace family for full console feel."
      }
    },
    "scale": {
      "xs": { "$type": "dimension", "$value": "0.75rem" },
      "sm": { "$type": "dimension", "$value": "0.875rem" },
      "base": { "$type": "dimension", "$value": "1rem" },
      "lg": { "$type": "dimension", "$value": "1.25rem" },
      "xl": { "$type": "dimension", "$value": "1.625rem" },
      "2xl": { "$type": "dimension", "$value": "2.125rem" },
      "3xl": { "$type": "dimension", "$value": "2.875rem" }
    },
    "weight": {
      "regular": { "$type": "fontWeight", "$value": 400 },
      "medium": { "$type": "fontWeight", "$value": 500 },
      "bold": { "$type": "fontWeight", "$value": 700 }
    },
    "tracking": {
      "tight": { "$type": "dimension", "$value": "-0.01em" },
      "normal": { "$type": "dimension", "$value": "0em" },
      "wide": { "$type": "dimension", "$value": "0.08em" },
      "caps": { "$type": "dimension", "$value": "0.18em" }
    },
    "leading": {
      "tight": { "$value": "1.15" },
      "normal": { "$value": "1.55" }
    }
  },
  "space": {
    "$type": "dimension",
    "0": { "$value": "0rem" },
    "1": { "$value": "0.25rem" },
    "2": { "$value": "0.5rem" },
    "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" },
    "5": { "$value": "1.5rem" },
    "6": { "$value": "2rem" },
    "7": { "$value": "3rem" },
    "8": { "$value": "4rem" }
  },
  "radius": {
    "$type": "dimension",
    "container": {
      "$value": "2px",
      "$description": "Panel / card radius. Near-square to read as a terminal frame."
    },
    "control": {
      "$value": "1px",
      "$description": "Buttons, inputs, chips. Crisp hard edges."
    }
  },
  "elevation": {
    "$description": "Glow-based elevation. Terminal panels lift via phosphor glow and inset scanline rather than soft drop shadows.",
    "flat": {
      "$type": "shadow",
      "$value": {
        "color": "#000000",
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "0px",
        "spread": "0px"
      }
    },
    "panel": {
      "$type": "shadow",
      "$value": [
        {
          "color": "rgba(0, 0, 0, 0.55)",
          "offsetX": "0px",
          "offsetY": "1px",
          "blur": "0px",
          "spread": "0px"
        },
        {
          "color": "rgba(57, 255, 139, 0.06)",
          "offsetX": "0px",
          "offsetY": "0px",
          "blur": "0px",
          "spread": "1px"
        }
      ]
    },
    "glow": {
      "$type": "shadow",
      "$value": {
        "color": "rgba(57, 255, 139, 0.35)",
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "18px",
        "spread": "0px"
      },
      "$description": "Active / focused phosphor glow for accent elements."
    },
    "glow-amber": {
      "$type": "shadow",
      "$value": {
        "color": "rgba(255, 182, 39, 0.32)",
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "16px",
        "spread": "0px"
      }
    }
  },
  "motion": {
    "duration": {
      "instant": { "$type": "duration", "$value": "80ms" },
      "fast": { "$type": "duration", "$value": "160ms" },
      "base": { "$type": "duration", "$value": "240ms" },
      "slow": { "$type": "duration", "$value": "420ms" },
      "type": { "$type": "duration", "$value": "2200ms", "$description": "Typewriter reveal duration for a line of text." },
      "blink": { "$type": "duration", "$value": "1000ms", "$description": "Cursor blink cycle." }
    },
    "easing": {
      "standard": { "$type": "cubicBezier", "$value": [0.2, 0, 0.2, 1] },
      "step": { "$value": "steps(24, end)", "$description": "Stepped easing for typewriter reveal." },
      "blink-step": { "$value": "steps(2, jump-none)", "$description": "Hard on/off cursor blink." }
    },
    "signature": {
      "$description": "Typewriter line reveal + a hard-blinking block cursor are the signature motions. Accent elements pulse their phosphor glow on hover/focus.",
      "typewriter": { "$value": "width var(--nt-duration-type) steps(24, end), opacity var(--nt-duration-fast)" },
      "cursor-blink": { "$value": "opacity var(--nt-duration-blink) steps(2, jump-none) infinite" },
      "glow-pulse": { "$value": "box-shadow var(--nt-duration-base) var(--nt-ease-standard)" }
    }
  }
}
