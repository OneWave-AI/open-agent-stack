{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "sand-terra — Warm editorial-organic theme on a dark base. Warm sand and terracotta on near-black, low-to-mid contrast, soft film grain. Rounded containers with warm diffuse shadows and hairline dividers. Serif display, humanist sans, slow easing-led motion. No purple. WCAG AA+ verified.",
  "color": {
    "bg": {
      "base": {
        "$type": "color",
        "$value": "#16110d",
        "$description": "Near-black warm brown. Page background."
      },
      "raised": {
        "$type": "color",
        "$value": "#1f1813",
        "$description": "Raised panel / section background, one step up from base."
      }
    },
    "surface": {
      "$type": "color",
      "$value": "#2a201a",
      "$description": "Card / container surface, sits above raised."
    },
    "text": {
      "primary": {
        "$type": "color",
        "$value": "#f3e7d8",
        "$description": "Warm sand foreground. 15.4:1 on bg.base (AAA)."
      },
      "muted": {
        "$type": "color",
        "$value": "#bda88f",
        "$description": "Muted warm sand for secondary text. 8.2:1 on bg.base (AAA)."
      }
    },
    "accent": {
      "$type": "color",
      "$value": "#e07a4f",
      "$description": "Terracotta accent. 6.3:1 on bg.base, 5.4:1 on surface (AA)."
    },
    "accent-strong": {
      "$type": "color",
      "$value": "#f0a079",
      "$description": "Lighter terracotta for hover / emphasis. 8.9:1 on bg.base (AAA)."
    },
    "border": {
      "$type": "color",
      "$value": "#3b2e24",
      "$description": "Container border, warm low-contrast."
    },
    "divider": {
      "$type": "color",
      "$value": "#2f241c",
      "$description": "Hairline divider, slightly below border."
    },
    "on-accent": {
      "$type": "color",
      "$value": "#1a1008",
      "$description": "Foreground on accent fills. 6.3:1 on accent (AA)."
    }
  },
  "type": {
    "font": {
      "display": {
        "$type": "fontFamily",
        "$value": ["Fraunces", "Georgia", "Cambria", "Times New Roman", "serif"],
        "$description": "Serif display for headings."
      },
      "body": {
        "$type": "fontFamily",
        "$value": ["Inter", "Segoe UI", "Helvetica Neue", "system-ui", "sans-serif"],
        "$description": "Humanist sans for body and UI."
      },
      "mono": {
        "$type": "fontFamily",
        "$value": ["JetBrains Mono", "SFMono-Regular", "Menlo", "Consolas", "monospace"],
        "$description": "Mono for code and tabular detail."
      }
    },
    "scale": {
      "xs": { "$type": "dimension", "$value": "0.75rem" },
      "sm": { "$type": "dimension", "$value": "0.875rem" },
      "base": { "$type": "dimension", "$value": "1rem" },
      "lg": { "$type": "dimension", "$value": "1.25rem" },
      "xl": { "$type": "dimension", "$value": "1.625rem" },
      "2xl": { "$type": "dimension", "$value": "2.125rem" },
      "3xl": { "$type": "dimension", "$value": "2.875rem" },
      "4xl": { "$type": "dimension", "$value": "3.875rem" }
    },
    "weight": {
      "regular": { "$type": "fontWeight", "$value": 400 },
      "medium": { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "display": { "$type": "fontWeight", "$value": 460 }
    },
    "leading": {
      "tight": { "$type": "number", "$value": 1.12 },
      "snug": { "$type": "number", "$value": 1.3 },
      "normal": { "$type": "number", "$value": 1.6 }
    }
  },
  "space": {
    "0": { "$type": "dimension", "$value": "0rem" },
    "1": { "$type": "dimension", "$value": "0.25rem" },
    "2": { "$type": "dimension", "$value": "0.5rem" },
    "3": { "$type": "dimension", "$value": "0.75rem" },
    "4": { "$type": "dimension", "$value": "1rem" },
    "5": { "$type": "dimension", "$value": "1.5rem" },
    "6": { "$type": "dimension", "$value": "2rem" },
    "7": { "$type": "dimension", "$value": "3rem" },
    "8": { "$type": "dimension", "$value": "4rem" },
    "9": { "$type": "dimension", "$value": "6rem" }
  },
  "radius": {
    "container": {
      "$type": "dimension",
      "$value": "1.25rem",
      "$description": "Rounded card / container radius."
    },
    "control": {
      "$type": "dimension",
      "$value": "0.625rem",
      "$description": "Buttons, inputs, small controls."
    },
    "pill": {
      "$type": "dimension",
      "$value": "999px",
      "$description": "Fully rounded chips and pills."
    }
  },
  "elevation": {
    "flat": {
      "$type": "shadow",
      "$value": {
        "color": "#00000000",
        "offsetX": "0rem",
        "offsetY": "0rem",
        "blur": "0rem",
        "spread": "0rem"
      },
      "$description": "No shadow."
    },
    "soft": {
      "$type": "shadow",
      "$value": [
        {
          "color": "rgba(10, 6, 3, 0.45)",
          "offsetX": "0rem",
          "offsetY": "0.5rem",
          "blur": "1.5rem",
          "spread": "-0.25rem"
        },
        {
          "color": "rgba(224, 122, 79, 0.06)",
          "offsetX": "0rem",
          "offsetY": "0.0625rem",
          "blur": "0rem",
          "spread": "0rem"
        }
      ],
      "$description": "Warm diffuse card shadow with a faint terracotta top hairline."
    },
    "lifted": {
      "$type": "shadow",
      "$value": [
        {
          "color": "rgba(8, 5, 2, 0.55)",
          "offsetX": "0rem",
          "offsetY": "1.25rem",
          "blur": "3rem",
          "spread": "-0.5rem"
        },
        {
          "color": "rgba(224, 122, 79, 0.08)",
          "offsetX": "0rem",
          "offsetY": "0.0625rem",
          "blur": "0rem",
          "spread": "0rem"
        }
      ],
      "$description": "Stronger warm diffuse shadow for hover / modal."
    }
  },
  "motion": {
    "duration": {
      "fast": { "$type": "duration", "$value": "180ms" },
      "base": { "$type": "duration", "$value": "320ms" },
      "slow": { "$type": "duration", "$value": "560ms" },
      "ambient": { "$type": "duration", "$value": "1200ms" }
    },
    "easing": {
      "standard": {
        "$type": "cubicBezier",
        "$value": [0.22, 0.61, 0.36, 1],
        "$description": "Slow ease-out for entrances."
      },
      "emphasized": {
        "$type": "cubicBezier",
        "$value": [0.16, 1, 0.3, 1],
        "$description": "Settled, organic deceleration."
      },
      "exit": {
        "$type": "cubicBezier",
        "$value": [0.4, 0, 0.7, 0.2],
        "$description": "Quicker ease-in for exits."
      }
    },
    "signature": {
      "$type": "transition",
      "$value": {
        "duration": "560ms",
        "timingFunction": [0.16, 1, 0.3, 1],
        "delay": "0ms"
      },
      "$description": "Signature move: slow easing-led rise-and-settle (translateY + fade) on reveal."
    }
  }
}
