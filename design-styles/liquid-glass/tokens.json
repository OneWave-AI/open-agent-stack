{
  "$schema": "https://design-tokens.org/schema.json",
  "$description": "Liquid Glass — translucent frosted-glass surfaces over deep slate with one high-vibrancy teal accent. Dark base, mid contrast, light edges and glow, springy parallax motion.",
  "color": {
    "$type": "color",
    "bg": {
      "base": { "$value": "#0a0f14", "$description": "Deepest slate canvas behind all glass" },
      "raised": { "$value": "#111922", "$description": "Slightly lifted base for stacked sections" }
    },
    "surface": {
      "$value": "rgba(28, 40, 53, 0.55)",
      "$description": "Frosted translucent glass container fill (pair with blur)"
    },
    "text": {
      "primary": { "$value": "#eef4f8", "$description": "Primary text, 14.8:1 on bg.base" },
      "muted": { "$value": "#9fb2bf", "$description": "Secondary text, 6.6:1 on bg.base" }
    },
    "accent": {
      "$value": "#2ee6c9",
      "$description": "High-vibrancy teal accent, 10.9:1 on bg.base"
    },
    "accent-strong": {
      "$value": "#14b8a6",
      "$description": "Deeper teal for fills behind dark text"
    },
    "border": {
      "$value": "rgba(190, 224, 240, 0.18)",
      "$description": "Light refractive edge on glass surfaces"
    },
    "divider": {
      "$value": "rgba(190, 224, 240, 0.12)",
      "$description": "Base color for soft light-gradient dividers"
    }
  },
  "type": {
    "font": {
      "display": { "$type": "fontFamily", "$value": ["Space Grotesk", "Inter", "system-ui", "sans-serif"] },
      "body": { "$type": "fontFamily", "$value": ["Inter", "system-ui", "-apple-system", "sans-serif"] },
      "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "ui-monospace", "SFMono-Regular", "monospace"] }
    },
    "scale": {
      "$type": "dimension",
      "xs": { "$value": "0.75rem" },
      "sm": { "$value": "0.875rem" },
      "base": { "$value": "1rem" },
      "lg": { "$value": "1.25rem" },
      "xl": { "$value": "1.75rem" },
      "2xl": { "$value": "2.5rem" },
      "3xl": { "$value": "3.5rem" }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 }
    },
    "tracking": {
      "$type": "dimension",
      "tight": { "$value": "-0.02em" },
      "normal": { "$value": "0em" }
    }
  },
  "space": {
    "$type": "dimension",
    "0": { "$value": "0rem" },
    "1": { "$value": "0.25rem" },
    "2": { "$value": "0.5rem" },
    "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" },
    "6": { "$value": "1.5rem" },
    "8": { "$value": "2rem" },
    "12": { "$value": "3rem" },
    "16": { "$value": "4rem" },
    "24": { "$value": "6rem" }
  },
  "radius": {
    "$type": "dimension",
    "control": { "$value": "0.625rem", "$description": "Buttons, inputs, chips" },
    "container": { "$value": "1.25rem", "$description": "Glass cards and panels" },
    "pill": { "$value": "9999px" }
  },
  "blur": {
    "$type": "dimension",
    "glass-sm": { "$value": "10px", "$description": "Light frost for chips and controls" },
    "glass": { "$value": "20px", "$description": "Standard frosted container backdrop blur" },
    "glass-lg": { "$value": "36px", "$description": "Heavy frost for hero panels" }
  },
  "elevation": {
    "$type": "shadow",
    "glass": {
      "$value": [
        { "color": "rgba(0, 0, 0, 0.45)", "offsetX": "0px", "offsetY": "12px", "blur": "40px", "spread": "-8px" },
        { "color": "rgba(46, 230, 201, 0.10)", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "1px" }
      ],
      "$description": "Depth shadow plus inner-edge teal glow ring"
    },
    "glow": {
      "$value": [
        { "color": "rgba(46, 230, 201, 0.35)", "offsetX": "0px", "offsetY": "0px", "blur": "28px", "spread": "0px" }
      ],
      "$description": "Accent glow for interactive focus states"
    }
  },
  "motion": {
    "duration": {
      "$type": "duration",
      "fast": { "$value": "160ms" },
      "base": { "$value": "280ms" },
      "slow": { "$value": "520ms" }
    },
    "easing": {
      "$type": "cubicBezier",
      "spring": { "$value": [0.34, 1.56, 0.64, 1], "$description": "Springy overshoot for parallax and reveals" },
      "glide": { "$value": [0.22, 1, 0.36, 1], "$description": "Smooth deceleration for surface transitions" }
    },
    "signature": {
      "$type": "string",
      "$value": "transform 520ms cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 280ms cubic-bezier(0.22, 1, 0.36, 1)",
      "$description": "Springy parallax lift: surfaces rise and gain glow on hover"
    }
  }
}
