{
  "$schema": "https://design-tokens.org/schema.json",
  "$description": "Tidal — ocean-depth dark theme. Deep ocean blues and teals fading to abyssal navy, foam-white text, sandy accents. Mid-to-high contrast, layered depth gradients with soft caustic-light shadows and subtle wave-line dividers.",
  "color": {
    "bg": {
      "base": {
        "$type": "color",
        "$value": "#04141f",
        "$description": "Abyssal navy — the deepest layer of the page background"
      },
      "raised": {
        "$type": "color",
        "$value": "#072636",
        "$description": "Deep ocean blue — raised panels and headers above the base"
      }
    },
    "surface": {
      "$type": "color",
      "$value": "#0c3a4f",
      "$description": "Teal-tinted surface for cards and containers"
    },
    "text": {
      "primary": {
        "$type": "color",
        "$value": "#eef9fb",
        "$description": "Foam white — primary text, ~15.8:1 on bg.base"
      },
      "muted": {
        "$type": "color",
        "$value": "#9fc4d0",
        "$description": "Sea mist — muted/secondary text, ~7.6:1 on bg.base"
      }
    },
    "accent": {
      "$type": "color",
      "$value": "#3fd0c9",
      "$description": "Caustic teal — primary accent for interactive elements"
    },
    "accent-warm": {
      "$type": "color",
      "$value": "#e8c79a",
      "$description": "Sandy gold — warm secondary accent"
    },
    "border": {
      "$type": "color",
      "$value": "#16526b",
      "$description": "Tidal border between surface and background"
    },
    "divider": {
      "$type": "color",
      "$value": "#1f6480",
      "$description": "Wave-line divider stroke color"
    }
  },
  "type": {
    "font": {
      "display": {
        "$type": "fontFamily",
        "$value": ["Quicksand", "Nunito", "Segoe UI", "system-ui", "sans-serif"],
        "$description": "Rounded humanist sans for display and headings"
      },
      "body": {
        "$type": "fontFamily",
        "$value": ["Nunito", "Quicksand", "Segoe UI", "system-ui", "sans-serif"],
        "$description": "Rounded humanist sans for body copy"
      },
      "mono": {
        "$type": "fontFamily",
        "$value": ["JetBrains Mono", "SFMono-Regular", "Menlo", "monospace"],
        "$description": "Monospace for code and tabular figures"
      }
    },
    "scale": {
      "xs": { "$type": "dimension", "$value": "0.75rem" },
      "sm": { "$type": "dimension", "$value": "0.875rem" },
      "base": { "$type": "dimension", "$value": "1rem" },
      "lg": { "$type": "dimension", "$value": "1.25rem" },
      "xl": { "$type": "dimension", "$value": "1.5rem" },
      "2xl": { "$type": "dimension", "$value": "2rem" },
      "3xl": { "$type": "dimension", "$value": "2.75rem" },
      "4xl": { "$type": "dimension", "$value": "3.75rem" }
    },
    "weight": {
      "regular": { "$type": "fontWeight", "$value": 400 },
      "medium": { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold": { "$type": "fontWeight", "$value": 700 }
    }
  },
  "space": {
    "0": { "$type": "dimension", "$value": "0rem" },
    "1": { "$type": "dimension", "$value": "0.25rem" },
    "2": { "$type": "dimension", "$value": "0.5rem" },
    "3": { "$type": "dimension", "$value": "0.75rem" },
    "4": { "$type": "dimension", "$value": "1rem" },
    "5": { "$type": "dimension", "$value": "1.5rem" },
    "6": { "$type": "dimension", "$value": "2rem" },
    "7": { "$type": "dimension", "$value": "3rem" },
    "8": { "$type": "dimension", "$value": "4rem" }
  },
  "radius": {
    "container": {
      "$type": "dimension",
      "$value": "1.5rem",
      "$description": "Smooth flowing container radius"
    },
    "control": {
      "$type": "dimension",
      "$value": "0.875rem",
      "$description": "Rounded control/button radius"
    },
    "pill": {
      "$type": "dimension",
      "$value": "9999px",
      "$description": "Fully rounded pill"
    }
  },
  "elevation": {
    "caustic-sm": {
      "$type": "shadow",
      "$value": {
        "color": "#02101a",
        "offsetX": "0rem",
        "offsetY": "0.25rem",
        "blur": "0.75rem",
        "spread": "0rem"
      },
      "$description": "Soft caustic-light shadow for raised surfaces"
    },
    "caustic-md": {
      "$type": "shadow",
      "$value": {
        "color": "#010a12",
        "offsetX": "0rem",
        "offsetY": "0.75rem",
        "blur": "1.75rem",
        "spread": "-0.25rem"
      },
      "$description": "Medium caustic shadow with teal under-glow pairing"
    },
    "caustic-glow": {
      "$type": "shadow",
      "$value": {
        "color": "#3fd0c933",
        "offsetX": "0rem",
        "offsetY": "0rem",
        "blur": "1.5rem",
        "spread": "0rem"
      },
      "$description": "Caustic teal glow used on accent/focus states"
    }
  },
  "blur": {
    "glass": {
      "$type": "dimension",
      "$value": "14px",
      "$description": "Backdrop blur for glassy floating containers"
    }
  },
  "motion": {
    "duration": {
      "fast": { "$type": "duration", "$value": "240ms" },
      "base": { "$type": "duration", "$value": "480ms" },
      "slow": { "$type": "duration", "$value": "900ms" },
      "current": { "$type": "duration", "$value": "6000ms" }
    },
    "easing": {
      "current": {
        "$type": "cubicBezier",
        "$value": [0.37, 0, 0.16, 1],
        "$description": "Slow fluid current-like ease"
      },
      "swell": {
        "$type": "cubicBezier",
        "$value": [0.45, 0.05, 0.25, 1],
        "$description": "Gentle swell ease for entrances"
      }
    },
    "signature": {
      "$type": "string",
      "$value": "drift 6000ms cubic-bezier(0.37, 0, 0.16, 1) infinite alternate",
      "$description": "Signature slow current drift — a continuous fluid translate/opacity sway"
    }
  }
}
