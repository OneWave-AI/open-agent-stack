{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Cirrus — a light cloud/sky design style. Soft whites and pale sky blues, airy frosted surfaces, large soft shadows, generous radius, and gentle floating motion.",
  "color": {
    "$type": "color",
    "bg": {
      "base": {
        "$value": "#eef4fb",
        "$description": "Page background — palest sky wash"
      },
      "raised": {
        "$value": "#f6fafe",
        "$description": "Slightly lifted background band"
      }
    },
    "surface": {
      "$value": "#fbfdff",
      "$description": "Frosted container fill — near-white with a sky tint"
    },
    "text": {
      "primary": {
        "$value": "#1c2b3a",
        "$description": "Primary text — deep slate blue (12.4:1 on bg.base)"
      },
      "muted": {
        "$value": "#4a5f73",
        "$description": "Secondary text — muted slate (6.1:1 on bg.base)"
      }
    },
    "accent": {
      "$value": "#1d6fb8",
      "$description": "Sky-blue accent for actions and links (4.9:1 on surface)"
    },
    "accent-contrast": {
      "$value": "#ffffff",
      "$description": "Text on accent fill (5.0:1 on accent)"
    },
    "border": {
      "$value": "#d4e2f0",
      "$description": "Hairline border on frosted surfaces"
    },
    "divider": {
      "$value": "#e3edf7",
      "$description": "Divider base color — meant to fade to nothing via gradient"
    }
  },
  "type": {
    "font": {
      "display": {
        "$type": "fontFamily",
        "$value": ["Quicksand", "Avenir Next", "Segoe UI", "system-ui", "sans-serif"],
        "$description": "Light geometric sans for headings"
      },
      "body": {
        "$type": "fontFamily",
        "$value": ["Inter", "Segoe UI", "system-ui", "-apple-system", "sans-serif"],
        "$description": "Clean humanist sans for body copy"
      },
      "mono": {
        "$type": "fontFamily",
        "$value": ["JetBrains Mono", "SFMono-Regular", "Menlo", "Consolas", "monospace"]
      }
    },
    "scale": {
      "$type": "dimension",
      "xs": { "$value": "0.75rem" },
      "sm": { "$value": "0.875rem" },
      "base": { "$value": "1rem" },
      "lg": { "$value": "1.25rem" },
      "xl": { "$value": "1.625rem" },
      "2xl": { "$value": "2.125rem" },
      "3xl": { "$value": "2.875rem" },
      "4xl": { "$value": "3.75rem" }
    },
    "weight": {
      "$type": "fontWeight",
      "light": { "$value": 300 },
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 }
    }
  },
  "space": {
    "$type": "dimension",
    "0": { "$value": "0rem" },
    "1": { "$value": "0.25rem" },
    "2": { "$value": "0.5rem" },
    "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" },
    "5": { "$value": "1.5rem" },
    "6": { "$value": "2rem" },
    "7": { "$value": "3rem" },
    "8": { "$value": "4rem" },
    "9": { "$value": "6rem" }
  },
  "radius": {
    "$type": "dimension",
    "container": { "$value": "1.75rem", "$description": "Generous radius for cards and panels" },
    "control": { "$value": "0.875rem", "$description": "Radius for buttons and inputs" }
  },
  "blur": {
    "$type": "dimension",
    "frost": { "$value": "16px", "$description": "Backdrop blur for frosted glass surfaces" },
    "frost-strong": { "$value": "28px", "$description": "Heavier frost for floating overlays" }
  },
  "elevation": {
    "$type": "shadow",
    "soft": {
      "$value": {
        "color": "rgba(91, 140, 191, 0.18)",
        "offsetX": "0px",
        "offsetY": "12px",
        "blur": "32px",
        "spread": "-8px"
      },
      "$description": "Large soft shadow for raised cards"
    },
    "float": {
      "$value": {
        "color": "rgba(91, 140, 191, 0.22)",
        "offsetX": "0px",
        "offsetY": "28px",
        "blur": "60px",
        "spread": "-12px"
      },
      "$description": "Deeper soft shadow for floating elements"
    }
  },
  "motion": {
    "duration": {
      "$type": "duration",
      "fast": { "$value": "200ms" },
      "base": { "$value": "420ms" },
      "slow": { "$value": "900ms" },
      "float": { "$value": "7000ms", "$description": "Loop duration for ambient floating" }
    },
    "easing": {
      "$type": "cubicBezier",
      "standard": { "$value": [0.4, 0.0, 0.2, 1] },
      "drift": { "$value": [0.37, 0.0, 0.27, 1], "$description": "Gentle, weightless easing" }
    },
    "signature": {
      "$type": "string",
      "$value": "float",
      "$description": "Slow vertical drift (translateY) with eased sine, evoking clouds adrift"
    }
  }
}
