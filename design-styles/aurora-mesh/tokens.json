{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "aurora-mesh — soft futuristic dark theme. Animated gradient-mesh backgrounds in teal, amber, and rose. Low contrast, glassy low-opacity cards, blurred orbs, gradient-fade dividers, rounded geometric sans, ambient drifting motion. No purple. WCAG AA+ verified.",
  "color": {
    "$type": "color",
    "bg": {
      "base": { "$value": "#0a1118", "$description": "Deep dark base canvas behind the mesh" },
      "raised": { "$value": "#101a24", "$description": "Slightly raised dark panel" }
    },
    "surface": { "$value": "rgba(22, 34, 46, 0.55)", "$description": "Glassy low-opacity card fill, used with backdrop blur" },
    "text": {
      "primary": { "$value": "#eef4f7", "$description": "Primary text — 15.6:1 on bg.base" },
      "muted": { "$value": "#a9bcc7", "$description": "Muted text — 7.9:1 on bg.base, AAA" }
    },
    "accent": {
      "teal": { "$value": "#3fd4c5", "$description": "Primary accent teal — 9.4:1 on bg.base" },
      "amber": { "$value": "#f5b94d", "$description": "Secondary accent amber — 10.7:1 on bg.base" },
      "rose": { "$value": "#f5849b", "$description": "Tertiary accent rose — 7.6:1 on bg.base" }
    },
    "border": { "$value": "rgba(143, 178, 196, 0.18)", "$description": "Hairline glass border" },
    "divider": { "$value": "rgba(143, 178, 196, 0.28)", "$description": "Base color for gradient-fade dividers" }
  },
  "type": {
    "font": {
      "display": { "$type": "fontFamily", "$value": ["Space Grotesk", "Outfit", "system-ui", "sans-serif"], "$description": "Rounded geometric sans for headings" },
      "body": { "$type": "fontFamily", "$value": ["Outfit", "system-ui", "-apple-system", "Segoe UI", "sans-serif"], "$description": "Rounded geometric sans for body" },
      "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "ui-monospace", "SFMono-Regular", "monospace"] }
    },
    "scale": {
      "xs": { "$type": "dimension", "$value": "0.75rem" },
      "sm": { "$type": "dimension", "$value": "0.875rem" },
      "base": { "$type": "dimension", "$value": "1rem" },
      "lg": { "$type": "dimension", "$value": "1.25rem" },
      "xl": { "$type": "dimension", "$value": "1.75rem" },
      "2xl": { "$type": "dimension", "$value": "2.5rem" },
      "3xl": { "$type": "dimension", "$value": "3.5rem" }
    },
    "weight": {
      "regular": { "$type": "fontWeight", "$value": 400 },
      "medium": { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold": { "$type": "fontWeight", "$value": 700 }
    }
  },
  "space": {
    "$type": "dimension",
    "0": { "$value": "0rem" },
    "1": { "$value": "0.25rem" },
    "2": { "$value": "0.5rem" },
    "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" },
    "5": { "$value": "1.5rem" },
    "6": { "$value": "2rem" },
    "7": { "$value": "3rem" },
    "8": { "$value": "4rem" }
  },
  "radius": {
    "$type": "dimension",
    "container": { "$value": "1.5rem", "$description": "Large soft radius for cards and panels" },
    "control": { "$value": "0.75rem", "$description": "Radius for buttons and inputs" },
    "pill": { "$value": "9999px" }
  },
  "blur": {
    "$type": "dimension",
    "glass": { "$value": "18px", "$description": "Backdrop blur for glass surfaces" },
    "orb": { "$value": "90px", "$description": "Heavy blur for ambient background orbs" }
  },
  "elevation": {
    "$type": "shadow",
    "card": {
      "$value": {
        "color": "rgba(4, 10, 16, 0.45)",
        "offsetX": "0px",
        "offsetY": "18px",
        "blur": "48px",
        "spread": "-12px"
      },
      "$description": "Soft diffuse drop for glass cards"
    },
    "glow": {
      "$value": {
        "color": "rgba(63, 212, 197, 0.30)",
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "32px",
        "spread": "0px"
      },
      "$description": "Teal accent glow for focused/hover controls"
    }
  },
  "motion": {
    "duration": {
      "$type": "duration",
      "fast": { "$value": "180ms" },
      "base": { "$value": "320ms" },
      "slow": { "$value": "640ms" },
      "drift": { "$value": "24000ms", "$description": "Ambient mesh/orb drift cycle" }
    },
    "easing": {
      "$type": "cubicBezier",
      "standard": { "$value": [0.4, 0, 0.2, 1] },
      "soft": { "$value": [0.33, 1, 0.68, 1], "$description": "Gentle ease-out for soft futuristic feel" },
      "drift": { "$value": [0.45, 0, 0.55, 1], "$description": "Symmetric ease for looping ambient motion" }
    },
    "signature": {
      "$type": "transition",
      "$value": {
        "property": "transform, opacity, background-position",
        "duration": "24000ms",
        "timingFunction": [0.45, 0, 0.55, 1]
      },
      "$description": "Signature: slow drifting gradient-mesh motion that never fully settles"
    }
  }
}
