# news-curator environment configuration
# Copy this file to .env and fill in values. Do not commit real secrets.
# Only required if your runtime's web search/fetch needs an external provider key.
# If your runtime provides built-in WebSearch/WebFetch, leave these unset.

# Search provider API key (e.g., Brave, SerpAPI, Tavily) used by WebSearch.
SEARCH_API_KEY=

# Optional: search provider base URL override.
SEARCH_API_BASE_URL=

# Optional: default locale bias for results.
DEFAULT_REGION=
DEFAULT_LANGUAGE=
