# Optional. Only needed if your runtime routes WebSearch through an external
# search provider instead of a built-in tool. Leave unset to use the built-in
# WebSearch tool. Never commit real keys.

# API key for an external web search provider (e.g. Serper, Bing, Brave).
SEO_AUDITOR_SEARCH_API_KEY=

# Optional override for the search provider endpoint.
SEO_AUDITOR_SEARCH_ENDPOINT=
