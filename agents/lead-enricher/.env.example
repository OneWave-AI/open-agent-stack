# lead-enricher environment
# Copy to .env and fill in. Never commit real secrets.

# Web search provider API key (only if your search tool needs one).
WEB_SEARCH_API_KEY=

# Web fetch / scraping proxy key (optional; only if your fetch tool needs one).
WEB_FETCH_API_KEY=

# Default output directory for written records (optional).
RECORD_OUTPUT_DIR=
